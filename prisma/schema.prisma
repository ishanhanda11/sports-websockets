// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  scheduled
  live
  finished
}

model Match {
  id         String        @id @default(cuid()) @map("id")
  sport      String        @map("sport")
  homeTeam   String        @map("home_team")
  awayTeam   String        @map("away_team")
  status     MatchStatus   @default(scheduled) @map("status")
  startTime  DateTime      @map("start_time")
  endTime    DateTime?     @map("end_time")
  homeScore  Int           @default(0) @map("home_score")
  awayScore  Int           @default(0) @map("away_score")
  createdAt  DateTime      @default(now()) @map("created_at")
  commentary Commentary[]

  @@map("matches")
  @@index([status])
  @@index([sport])
}

model Commentary {
  id        String   @id @default(cuid()) @map("id")
  matchId   String   @map("match_id")
  match     Match    @relation(fields: [matchId], references: [id])
  minute    Int      @map("minute")
  sequence  Int      @map("sequence")
  period    String   @map("period")
  eventType String   @map("event_type")
  actor     String   @map("actor")
  team      String   @map("team")
  message   String   @map("message")
  metadata  Json     @map("metadata")
  tags      String[] @map("tags")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("commentary")
  @@index([matchId])
}